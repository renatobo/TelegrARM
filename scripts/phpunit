#!/bin/bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TOOLS_DIR="$ROOT_DIR/.tools/phpunit"
PHPUNIT_PHAR="$TOOLS_DIR/phpunit.phar"
PHPUNIT_URL="https://phar.phpunit.de/phpunit-9.phar"

mkdir -p "$TOOLS_DIR"

if [[ ! -f "$PHPUNIT_PHAR" ]]; then
  echo "Downloading PHPUnit to $PHPUNIT_PHAR"
  curl -fsSL "$PHPUNIT_URL" -o "$PHPUNIT_PHAR"
  chmod +x "$PHPUNIT_PHAR"
fi

exec php "$PHPUNIT_PHAR" --configuration="$ROOT_DIR/phpunit.xml.dist" "$@"
